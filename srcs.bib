	journal = {BMC Microbiology},
	author = {Bickhart, Derek M. and Benson, David R.},
	month = aug,
	year = {2011},
	keywords = {Frankia Strain, Strain CcI3, CRISPR Array, Frankial Genome, Putative SNPs},
