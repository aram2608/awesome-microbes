	file = {Full Text PDF:/Users/ja1473/Zotero/storage/I5UNT8TQ/Cantalapiedra et al. - 2021 - eggNOG-mapper v2 Functional Annotation, Orthology Assignments, and Domain Prediction at the Metagen.pdf:application/pdf;Snapshot:/Users/ja1473/Zotero/storage/8X9BMQN8/6379734.html:text/html},
}

