@article{kim_graph-based_2019,
	title = {Graph-based genome alignment and genotyping with {HISAT2} and {HISAT}-genotype},
	volume = {37},
	copyright = {2019 The Author(s), under exclusive licence to Springer Nature America, Inc.},
