	volume = {12},
	issn = {1664-302X},
	shorttitle = {Alone {Yet} {Not} {Alone}},
	url = {https://www.frontiersin.org/journals/microbiology/articles/10.3389/fmicb.2021.749760/full},
	doi = {10.3389/fmicb.2021.749760},
	abstract = {{\textless}p{\textgreater}Actinorhizal plants host mutualistic symbionts of the nitrogen-fixing actinobacterial genus {\textless}italic{\textgreater}Frankia{\textless}/italic{\textgreater} within nodule structures formed on their roots. Several plant-growth-promoting bacteria have also been isolated from actinorhizal root nodules, but little is known about them. We were interested investigating the {\textless}italic{\textgreater}in planta{\textless}/italic{\textgreater} microbial community composition of actinorhizal root nodules using culture-independent techniques. To address this knowledge gap, 16S rRNA gene amplicon and shotgun metagenomic sequencing was performed on DNA from the nodules of {\textless}italic{\textgreater}Casuarina glauca.{\textless}/italic{\textgreater} DNA was extracted from {\textless}italic{\textgreater}C. glauca{\textless}/italic{\textgreater} nodules collected in three different sampling sites in Tunisia, along a gradient of aridity ranging from humid to arid. Sequencing libraries were prepared using Illumina NextEra technology and the Illumina HiSeq 2500 platform. Genome bins extracted from the metagenome were taxonomically and functionally profiled. Community structure based off preliminary 16S rRNA gene amplicon data was analyzed {\textless}italic{\textgreater}via{\textless}/italic{\textgreater} the QIIME pipeline. Reconstructed genomes were comprised of members of {\textless}italic{\textgreater}Frankia{\textless}/italic{\textgreater}, {\textless}italic{\textgreater}Micromonospora{\textless}/italic{\textgreater}, {\textless}italic{\textgreater}Bacillus{\textless}/italic{\textgreater}, {\textless}italic{\textgreater}Paenibacillus{\textless}/italic{\textgreater}, {\textless}italic{\textgreater}Phyllobacterium{\textless}/italic{\textgreater}, and {\textless}italic{\textgreater}Afipia{\textless}/italic{\textgreater}. {\textless}italic{\textgreater}Frankia{\textless}/italic{\textgreater} dominated the nodule community at the humid sampling site, while the absolute and relative prevalence of {\textless}italic{\textgreater}Frankia{\textless}/italic{\textgreater} decreased at the semi-arid and arid sampling locations. Actinorhizal plants harbor similar non-{\textless}italic{\textgreater}Frankia{\textless}/italic{\textgreater} plant-growth-promoting-bacteria as legumes and other plants. The data suggests that the prevalence of {\textless}italic{\textgreater}Frankia{\textless}/italic{\textgreater} in the nodule community is influenced by environmental factors, with being less abundant under more arid environments.{\textless}/p{\textgreater}},
	language = {English},
	urldate = {2025-02-19},
	journal = {Frontiers in Microbiology},
	publisher = {Frontiers},
	author = {Ghodhbane-Gtari, Faten and D’Angelo, Timothy and Gueddou, Abdellatif and Ghazouani, Sabrine and Gtari, Maher and Tisa, Louis S.},
	month = dec,
	year = {2021},
	keywords = {Actinorhizal symbiosis, endophyte, microbiome, Plant-growth- promoting bacteria, symbiont},
	file = {Full Text PDF:/Users/ja1473/Zotero/storage/SGABJ7BG/Ghodhbane-Gtari et al. - 2021 - Alone Yet Not Alone Frankia Lives Under the Same Roof With Other Bacteria in Actinorhizal Nodules.pdf:application/pdf},
}

@article{nickel_effect_2001,
	title = {Effect of {Inoculation} and {Leaf} {Litter} {Amendment} on {Establishment} of {Nodule}-{Forming} {Frankia} {Populations} in {Soil}},
	volume = {67},
	url = {https://journals.asm.org/doi/10.1128/aem.67.6.2603-2609.2001},
	doi = {10.1128/AEM.67.6.2603-2609.2001},
	abstract = {High-N2-fixing activities of Frankiapopulations in root nodules on Alnus glutinosa improve growth performance of the host plant. Therefore, the establishment of active, nodule-forming populations of Frankia in soil is desirable. In this study, we inoculated Frankia strains of Alnus host infection groups I, IIIa, and IV into soil already harboring indigenous populations of infection groups (IIIa, IIIb, and IV). Then we amended parts of the inoculated soil with leaf litter of A. glutinosa and kept these parts of soil without host plants for several weeks until they were spiked with [15N]NO3 and planted with seedlings ofA. glutinosa. After 4 months of growth, we analyzed plants for growth performance, nodule formation, specificFrankia populations in root nodules, and N2fixation rates. The results revealed that introducedFrankia strains incubated in soil for several weeks in the absence of plants remained infective and competitive for nodulation with the indigenous Frankia populations of the soil. Inoculation into and incubation in soil without host plants generally supported subsequent plant growth performance and increased the percentage of nitrogen acquired by the host plants through N2 fixation from 33\% on noninoculated, nonamended soils to 78\% on inoculated, amended soils. Introduced Frankiastrains representing Alnus host infection groups IIIa and IV competed with indigenous Frankia populations, whereas frankiae of group I were not found in any nodules. When grown in noninoculated, nonamended soil, A. glutinosa plants harbored Frankia populations of only group IIIa in root nodules. This group was reduced to 32\% ± 23\% (standard deviation) of the Frankia nodule populations when plants were grown in inoculated, nonamended soil. Under these conditions, the introducedFrankia strain of group IV was established in 51\% ± 20\% of the nodules. Leaf litter amendment during the initial incubation in soil without plants promoted nodulation by frankiae of group IV in both inoculated and noninoculated treatments. Grown in inoculated, amended soils, plants had significantly lower numbers of nodules infected by group IIIa (8\% ± 6\%) than by group IV (81\% ± 11\%). On plants grown in noninoculated, amended soil, the originalFrankia root nodule population represented by group IIIa of the noninoculated, nonamended soil was entirely exchanged by aFrankia population belonging to group IV. The quantification of N2 fixation rates by 15N dilution revealed that both the indigenous and the inoculatedFrankia populations of group IV had a higher specific N2-fixing capacity than populations belonging to group IIIa under the conditions applied. These results show that through inoculation or leaf litter amendment, Frankiapopulations with high specific N2-fixing capacities can be established in soils. These populations remain infective on their host plants, successfully compete for nodule formation with other indigenous or inoculated Frankia populations, and thereby increase plant growth performance.},
	number = {6},
	urldate = {2025-03-02},
	journal = {Applied and Environmental Microbiology},
	publisher = {American Society for Microbiology},
	author = {Nickel, Anja and Pelz, Oliver and Hahn, Dittmar and Saurer, Matthias and Siegwolf, Rolf and Zeyer, Josef},
	month = jun,
	year = {2001},
	pages = {2603--2609},
	file = {Full Text PDF:/Users/ja1473/Zotero/storage/UUB83JYV/Nickel et al. - 2001 - Effect of Inoculation and Leaf Litter Amendment on Establishment of Nodule-Forming Frankia Populatio.pdf:application/pdf},
}

@article{thomas_effects_1989,
	title = {Effects of continuous nitrogen application and nitrogen preconditioning on nodulation and growth {ofCeanothus} griseus varhorizontalis},
	volume = {118},
	issn = {1573-5036},
	url = {https://doi.org/10.1007/BF02232805},
	doi = {10.1007/BF02232805},
	abstract = {Rooted cuttings ofCeanothus griseus varhorizontalis were irrigated with 0, 10, 20, 50, 75 or 100ppm nitrogen as NH4NO3 for eight weeks prior to inoculation with infectiveFrankia. After inoculation, half of the plants for each treatment nitrogen level continued to be irrigated with the preconditioning nitrogen level and half were given no more supplemental nitrogen. For plants continuously receiving nitrogen, nodule initiation (nodule number) was inversely correlated with increasing supplemental nitrogen levels, and suppressed above 50 ppm N. Leaf nitrogen above 2\% in continuous-N plants correlated with greatly reduced or suppressed nodulation. Plants maintained after inoculation without supplemental nitrogen showed influence of the prior nitrogen treatment on nodulation. Preconditioning at 50 ppm and above greatly reduced the number of nodules formed. The evidence suggests that stored internal nitrogen can regulate nodulation.},
	language = {en},
	number = {1},
	urldate = {2025-03-03},
	journal = {Plant and Soil},
	author = {Thomas, Kathryn A. and Berry, Alison M.},
	month = aug,
	year = {1989},
	keywords = {Frankia, actinorhizal, nodulation, nitrogen, Ceanothus, inoculation, propagation},
	pages = {181--187},
	file = {Full Text PDF:/Users/ja1473/Zotero/storage/FFC3DPJR/Thomas and Berry - 1989 - Effects of continuous nitrogen application and nitrogen preconditioning on nodulation and growth ofC.pdf:application/pdf},
}

