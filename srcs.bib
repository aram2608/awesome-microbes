	keywords = {Actinorhizal symbiosis, Casuarina glauca, in situ hybridization, nitrogen-fixing nodules, plant hemoglobins},
	pages = {608--616},
	file = {Full Text PDF:/Users/ja1473/Zotero/storage/ZU5Z26XE/Gherbi et al. - 1997 - Cloning of a full-length symbiotic hemoglobin cDNA and in situ localization of the corresponding mRN.pdf:application/pdf;Snapshot:/Users/ja1473/Zotero/storage/VFFYNGXR/j.1399-3054.1997.tb05364.html:text/html},
