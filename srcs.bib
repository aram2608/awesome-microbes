@article{hocher_expressed_2006,
	title = {Expressed sequence-tag analysis in {Casuarina} glauca actinorhizal nodule and root},
	volume = {169},
	issn = {1469-8137},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/j.1469-8137.2006.01644.x},
	doi = {10.1111/j.1469-8137.2006.01644.x},
	abstract = {• The present study aimed to identify and assess the frequency and tissue specificity of plant genes in the actinorhizal Casuarina glauca–Frankia symbiosis through expressed sequence tag (EST) analysis. • Using a custom analysis pipeline for raw sequences of C. glauca uninfected roots and nodules, we obtained an EST databank web interface. Gene expression was studied in nodules vs roots using comparative quantitative real-time reverse transcription–polymerase chain reaction (qRT–PCR). • From roots and nodules, 2028 ESTs were created and clustered in 242 contigs and 1429 singletons, giving a total of 1616 unique genes. Half the nodule transcripts showed no similarity to previously identified genes. Genes of primary metabolism, protein synthesis, cell division and defence were highly represented in the nodule library. Differential expression was observed between roots and nodules for several genes linked to primary metabolism and flavonoid biosynthesis. • This comparative EST-based study provides the first picture of the set of genes expressed during actinorhizal symbiosis. We consider our database to be a flexible tool that can be used for the management of EST data from other actinorhizal symbioses.},
	language = {en},
	number = {4},
	urldate = {2026-03-26},
	journal = {New Phytologist},
	author = {Hocher, Valérie and Auguy, Florence and Argout, Xavier and Laplaze, Laurent and Franche, Claudine and Bogusz, Didier},
	year = {2006},
	note = {\_eprint: https://nph.onlinelibrary.wiley.com/doi/pdf/10.1111/j.1469-8137.2006.01644.x},
	keywords = {actinorhizal symbiosis, Casuarina glauca, expressed sequence tags (ESTs), Frankia, quantitative real time RT–PCR (qRT–PCR)},
	pages = {681--688},
	file = {Full Text PDF:/Users/ja1473/Zotero/storage/ZHT6HYH5/Hocher et al. - 2006 - Expressed sequence-tag analysis in Casuarina glauca actinorhizal nodule and root.pdf:application/pdf;Snapshot:/Users/ja1473/Zotero/storage/YMPKP44S/j.1469-8137.2006.01644.html:text/html},
}

