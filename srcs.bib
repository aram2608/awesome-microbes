@article{ott_symbiotic_2005,
	title = {Symbiotic {Leghemoglobins} {Are} {Crucial} for {Nitrogen} {Fixation} in {Legume} {Root} {Nodules} but {Not} for {General} {Plant} {Growth} and {Development}},
	volume = {15},
	issn = {0960-9822},
	url = {https://www.sciencedirect.com/science/article/pii/S0960982205001077},
	doi = {10.1016/j.cub.2005.01.042},
	abstract = {Hemoglobins are ubiquitous in nature and among the best-characterized proteins [1, 2, 3, 4, 5, 6, 7, 8, 9]. Genetics has revealed crucial roles for human hemoglobins [10], but similar data are lacking for plants. Plants contain symbiotic and nonsymbiotic hemoglobins [11]; the former are thought to be important for symbiotic nitrogen fixation (SNF). In legumes, SNF occurs in specialized organs, called nodules, which contain millions of nitrogen-fixing rhizobia, called bacteroids [12, 13]. The induction of nodule-specific plant genes, including those encoding symbiotic leghemoglobins (Lb), accompanies nodule development [14, 15]. Leghemoglobins accumulate to millimolar concentrations in the cytoplasm of infected plant cells prior to nitrogen fixation and are thought to buffer free oxygen in the nanomolar range, avoiding inactivation of oxygen-labile nitrogenase while maintaining high oxygen flux for respiration [16]. Although widely accepted, this hypothesis has never been tested in planta. Using RNAi, we abolished symbiotic leghemoglobin synthesis in nodules of the model legume Lotus japonicus. This caused an increase in nodule free oxygen, a decrease in the ATP/ADP ratio, loss of bacterial nitrogenase protein, and absence of SNF. However, LbRNAi plants grew normally when fertilized with mineral nitrogen. These data indicate roles for leghemoglobins in oxygen transport and buffering and prove for the first time that plant hemoglobins are crucial for symbiotic nitrogen fixation.},
	number = {6},
	urldate = {2025-05-05},
	journal = {Current Biology},
	author = {Ott, Thomas and van Dongen, Joost T. and Gu¨nther, Catrin and Krusell, Lene and Desbrosses, Guilhem and Vigeolas, Helene and Bock, Vivien and Czechowski, Tomasz and Geigenberger, Peter and Udvardi, Michael K.},
	month = mar,
	year = {2005},
	pages = {531--535},
	file = {Full Text:/Users/ja1473/Zotero/storage/CN95DC69/Ott et al. - 2005 - Symbiotic Leghemoglobins Are Crucial for Nitrogen Fixation in Legume Root Nodules but Not for Genera.pdf:application/pdf},
}

