	title = {Expanding our {Understanding} of {Sequence}-{Function} {Relationships} of {Type} {II} {Polyketide} {Biosynthetic} {Gene} {Clusters}: {Bioinformatics}-{Guided} {Identification} of {Frankiamicin} {A} from {Frankia} sp. {EAN1pec}},
