@article{peret_auxin_2007-2,
	title = {Auxin {Influx} {Activity} {Is} {Associated} with {Frankia} {Infection} during {Actinorhizal} {Nodule} {Formation} in {Casuarina} glauca},
	volume = {144},
	issn = {0032-0889},
	url = {https://doi.org/10.1104/pp.107.101337},
	doi = {10.1104/pp.107.101337},
	abstract = {Plants from the Casuarinaceae family enter symbiosis with the actinomycete Frankia leading to the formation of nitrogen-fixing root nodules. We observed that application of the auxin influx inhibitor 1-naphtoxyacetic acid perturbs actinorhizal nodule formation. This suggests a potential role for auxin influx carriers in the infection process. We therefore isolated and characterized homologs of the auxin influx carrier (AUX1-LAX) genes in Casuarina glauca. Two members of this family were found to share high levels of deduced protein sequence identity with Arabidopsis (Arabidopsis thaliana) AUX-LAX proteins. Complementation of the Arabidopsis aux1 mutant revealed that one of them is functionally equivalent to AUX1 and was named CgAUX1. The spatial and temporal expression pattern of CgAUX1 promoter:β-glucuronidase reporter was analyzed in Casuarinaceae. We observed that CgAUX1 was expressed in plant cells infected by Frankia throughout the course of actinorhizal nodule formation. Our data suggest that auxin plays an important role during plant cell infection in actinorhizal symbioses.},
	number = {4},
	urldate = {2025-05-02},
	journal = {Plant Physiology},
	author = {Péret, Benjamin and Swarup, Ranjan and Jansen, Leen and Devos, Gaëlle and Auguy, Florence and Collin, Myriam and Santi, Carole and Hocher, Valérie and Franche, Claudine and Bogusz, Didier and Bennett, Malcolm and Laplaze, Laurent},
	month = aug,
	year = {2007},
	pages = {1852--1862},
	file = {Full Text PDF:/Users/ja1473/Zotero/storage/J5YZ53SR/Péret et al. - 2007 - Auxin Influx Activity Is Associated with Frankia Infection during Actinorhizal Nodule Formation in C.pdf:application/pdf;Snapshot:/Users/ja1473/Zotero/storage/B8T7NSZG/6106707.html:text/html},
}

@article{hammad_possible_2003-1,
	title = {A possible role for phenyl acetic acid ({PAA}) on {Alnus} glutinosa nodulation by {Frankia}},
	volume = {254},
	issn = {1573-5036},
	url = {https://doi.org/10.1023/A:1024971417777},
	doi = {10.1023/A:1024971417777},
	abstract = {Phenylacetic hopanetetrol is a Frankia specific lipid present in vesicles. Phenylacetic acid (PAA) is known as an auxinomimetic, exhibiting the same effect on plant growth as indole acetic acid (IAA). We hypothesize that PAA, only bound by an ester link to the hopanetetrol basic unit, would be easily released and could thus play a role in nodule formation. HPLC and mass spectrometry analysis allowed us to show that 2 Alnus- (ACoN24d and ACN14a) and 2 Elaeagnus-infective strains (EaI1 and EaI3) released PAA into the culture medium, at concentrations of about 10−5 to 10−6 M, whereas IAA was not detected. Furthermore, exogenous PAA added to axenically-grown Alnus glutinosa roots at a concentration of 5×10−5 M, resulted in the formation of thick, short lateral roots which resembled actinorhizal nodules. phenylalanine ammonia lyase (PAL) and chalcone syntase (CHS) induction by incompatible and compatible Frankia strains in A. glutinosa roots and the different contents in salicylic acid precursors (cinnamic acid and benzoic acid) observed between nodules and roots support the idea that PAA would be produced in nodules to the detriment of salicylic acid production. These results provide evidence that in actinorhizal root nodules, phenylpropanoid metabolism may play a multiple role in symbiotic interactions including the limitation of the induction of the systematic acquired resistance (SAR) by the plant.},
	language = {en},
	number = {1},
	urldate = {2025-05-02},
	journal = {Plant and Soil},
	author = {Hammad, Yaser and Nalin, Renaud and Marechal, Joelle and Fiasson, Katia and Pepin, Régis and Berry, Alison M. and Normand, Philippe and Domenach, Anne-Marie},
	month = jul,
	year = {2003},
	keywords = {auxin, hopanoids, CHS, PAL, phenolic acids},
	pages = {193--205},
	file = {Full Text PDF:/Users/ja1473/Zotero/storage/3YPDBULK/Hammad et al. - 2003 - A possible role for phenyl acetic acid (PAA) on Alnus glutinosa nodulation by Frankia.pdf:application/pdf},
}

@article{svistoonoff_cg12_2003-2,
	title = {cg12 {Expression} {Is} {Specifically} {Linked} to {Infection} of {Root} {Hairs} and {Cortical} {Cells} during {Casuarina} glauca and {Allocasuarina} verticillata {Actinorhizal} {Nodule} {Development}},
	volume = {16},
	issn = {0894-0282},
	url = {https://apsjournals.apsnet.org/doi/10.1094/MPMI.2003.16.7.600},
	doi = {10.1094/MPMI.2003.16.7.600},
	abstract = {cg12 is an early actinorhizal nodulin gene from Casuarina glauca encoding a subtilisin-like serine protease. Using transgenic Casuarinaceae plants carrying cg12-gus and cg12-gfp fusions, we have studied the expression pattern conferred by the cg12 promoter region after inoculation with Frankia. cg12 was found to be expressed in root hairs and in root and nodule cortical cells containing Frankia infection threads. cg12 expression was also monitored after inoculation with ineffective Frankia strains, during my-corrhizae formation, and after diverse hormonal treatments. None of these treatments was able to induce its expression, therefore suggesting that cg12 expression is linked to plant cell infection by Frankia strains. Possible roles of cg12 in actinorhizal symbiosis are discussed.},
	number = {7},
	urldate = {2025-05-04},
	journal = {Molecular Plant-Microbe Interactions®},
	publisher = {Scientific Societies},
	author = {Svistoonoff, Sergio and Laplaze, Laurent and Auguy, Florence and Runions, John and Duponnois, Robin and Haseloff, Jim and Franche, Claudine and Bogusz, Didier},
	month = jul,
	year = {2003},
	keywords = {genetic transformation, Nod factors, subtilase},
	pages = {600--607},
	file = {Full Text PDF:/Users/ja1473/Zotero/storage/5DMYUSPE/Svistoonoff et al. - 2003 - cg12 Expression Is Specifically Linked to Infection of Root Hairs and Cortical Cells during Casuarin.pdf:application/pdf},
}

