	file = {ScienceDirect Full Text PDF:/Users/ja1473/Zotero/storage/DKZ5JEEF/Champidou et al. - 2025 - Modeling Geobacillus stearothermophilus spores inactivation in plant-based drinks to design U.pdf:application/pdf;ScienceDirect Snapshot:/Users/ja1473/Zotero/storage/HLIG8XGZ/S0963996924015886.html:text/html},
}

