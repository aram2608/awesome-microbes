@article{gomez-escribano_engineering_2011,
	title = {Engineering {Streptomyces} coelicolor for heterologous expression of secondary metabolite gene clusters},
	volume = {4},
	copyright = {© 2010 The Authors. Journal compilation © 2010 Society for Applied Microbiology and Blackwell Publishing Ltd},
	issn = {1751-7915},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/j.1751-7915.2010.00219.x},
	doi = {10.1111/j.1751-7915.2010.00219.x},
	abstract = {We have constructed derivatives of Streptomyces coelicolor M145 as hosts for the heterologous expression of secondary metabolite gene clusters. To remove potentially competitive sinks of carbon and nitrogen, and to provide a host devoid of antibiotic activity, we deleted four endogenous secondary metabolite gene clusters from S. coelicolor M145 – those for actinorhodin, prodiginine, CPK and CDA biosynthesis. We then introduced point mutations into rpoB and rpsL to pleiotropically increase the level of secondary metabolite production. Introduction of the native actinorhodin gene cluster and of gene clusters for the heterologous production of chloramphenicol and congocidine revealed dramatic increases in antibiotic production compared with the parental strain. In addition to lacking antibacterial activity, the engineered strains possess relatively simple extracellular metabolite profiles. When combined with liquid chromatography and mass spectrometry, we believe that these genetically engineered strains will markedly facilitate the discovery of new compounds by heterologous expression of cloned gene clusters, particularly the numerous cryptic secondary metabolic gene clusters that are prevalent within actinomycete genome sequences.},
	language = {en},
	number = {2},
	urldate = {2024-10-17},
	journal = {Microbial Biotechnology},
	author = {Gomez-Escribano, Juan Pablo and Bibb, Mervyn J.},
	year = {2011},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/j.1751-7915.2010.00219.x},
	pages = {207--215},
	file = {Full Text:/Users/ja1473/Zotero/storage/B8LVEZIQ/Gomez-Escribano and Bibb - 2011 - Engineering Streptomyces coelicolor for heterologous expression of secondary metabolite gene cluster.pdf:application/pdf;Snapshot:/Users/ja1473/Zotero/storage/VGA63PA7/j.1751-7915.2010.00219.html:text/html},
}

