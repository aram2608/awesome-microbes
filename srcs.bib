	month = apr,
	year = {2014},
	pages = {923--930},
	file = {Full Text PDF:/Users/ja1473/Zotero/storage/RVK5A7PJ/Liao et al. - 2014 - featureCounts an efficient general purpose program for assigning sequence reads to genomic features.pdf:application/pdf;Snapshot:/Users/ja1473/Zotero/storage/FVJKPJ2I/232889.html:text/html},
}

@article{cantalapiedra_eggnog-mapper_2021-1,
	title = {{eggNOG}-mapper v2: {Functional} {Annotation}, {Orthology} {Assignments}, and {Domain} {Prediction} at the {Metagenomic} {Scale}},
