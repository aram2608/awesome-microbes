@article{liaqat_climate_2022,
	title = {Climate change in relation to agriculture: {A} review},
	volume = {20},
	issn = {1695-971X},
	shorttitle = {Climate change in relation to agriculture},
	url = {https://avesis.cu.edu.tr/yayin/f81f167e-23ba-4bfb-86a7-b6971622351b/climate-change-in-relation-to-agriculture-a-review},
	doi = {10.5424/sjar/2022202-17742},
	abstract = {Climate change is among the most crucial concerns of the world. It is a serious threat to the global agriculture and its overall impact on global agriculture is yet not clear. A rise of 2.5-4.5 degrees C is expected in the global temperature until the end of 21st century. The amount of greenhouse gases particularly CO2 is increasing at an alarming rate and is enhancing the plant photosynthesis and productivity. However, this increase in productivity is counteract by the more negative effects of climate change on agriculture like increased evapotranspiration, drought, floods, changes in the amount and distribution of rainfall, higher pest infestations and more irrigation demand. Climate change also affects the nutrients availability and efficiency by influencing microbial activities and population in the soil. Therefore, adaptation of agriculture sector to the changing climate is indispensable because of its sensitivity and size. This review is aimed to document the possible impacts of climate change on agriculture, its causes and future projections. Some strategies are also advised to mitigate the emission of greenhouse gases, to reduce the negative impacts of climate change on agriculture and to make new policies keeping in view their broader consequences on agriculture.},
	language = {eng},
	number = {2},
	urldate = {2024-11-16},
	journal = {SPANISH JOURNAL OF AGRICULTURAL RESEARCH},
	author = {Liaqat, Waqas and Barutçular, Celaleddi̇n and Farooq, Muhammad and Ahmad, Haseeb and Jan, Muhammad and Ahmad, Zahoor and Nawaz, Haq and Li, Ming},
	year = {2022},
	file = {Full Text PDF:/Users/ja1473/Zotero/storage/G59U3TR7/Liaqat et al. - 2022 - Climate change in relation to agriculture A review.pdf:application/pdf},
}

@article{malhi_impact_2021,
